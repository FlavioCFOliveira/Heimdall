#:schema ./heimdall.toml.schema.json
# Heimdall reference configuration
# Copy to /etc/heimdall/heimdall.toml and edit as required.
#
# Full reference: docs/configuration-reference.md
# Boot-sequence: docs/operator/boot.md
# Security policy: specification/007-threat-model.md
#
# SAFE DEFAULTS:
#   - No roles active until explicitly enabled.
#   - No listeners until explicitly configured.
#   - Recursive resolver binds to 127.0.0.1 only (open-resolver mitigation,
#     specification/007 THREAT-035).
#   - Admin-RPC and observability bind to loopback only.
#   - DoT/DoH/DoQ are commented out — they require valid TLS material.

# ── Server identity and runtime ───────────────────────────────────────────────

[server]
# NSID returned in EDNS responses (RFC 5001).  Used to identify this node
# in anycast/multi-server deployments.
identity = "heimdall"

# Worker thread count for the Tokio runtime.
# Default: number of logical CPUs (recommended for production).
# worker_threads = 8

# Grace period (seconds) for draining in-flight queries after SIGTERM.
# Systemd stop timeout (TimeoutStopSec) should be >= drain_grace_secs + 5.
drain_grace_secs = 30

# ── Resource limits ───────────────────────────────────────────────────────────
# Applied at boot phase 13 (BIN-036..038, THREAT-068).
# Values are soft limits; each is capped to the process hard limit at runtime.
# Failures to apply are logged at WARN level and are never fatal.

[rlimit]
# Maximum number of open file descriptors.
nofile = 1_048_576

# Maximum number of processes (Linux only, per-uid).
nproc = 8_192

# Maximum core dump size in bytes. Set to 0 to disable core dumps.
core = 0

# ── Roles ─────────────────────────────────────────────────────────────────────
# At least one role must be true when [[listeners]] are configured.
# See specification/001-recursive.md, 003-authoritative.md, 005-forwarder.md.

[roles]
# Perform full recursive resolution with DNSSEC validation.
# Bind listeners to 127.0.0.1 / ::1 to prevent becoming an open resolver.
recursive = false

# Serve authoritative answers from zone files configured in [zones].
authoritative = false

# Forward queries to upstream resolvers (configured in a future release).
forwarder = false

# ── Listeners ─────────────────────────────────────────────────────────────────
# At least one [[listeners]] entry is required when a role is active.
# Ports below 1024 require CAP_NET_BIND_SERVICE (set automatically by the
# systemd unit via AmbientCapabilities=CAP_NET_BIND_SERVICE).

# DNS-over-UDP (RFC 1035) — standard DNS port.
[[listeners]]
address = "127.0.0.1"
port = 53
transport = "udp"

# DNS-over-TCP (RFC 7766) — same port as UDP.
[[listeners]]
address = "127.0.0.1"
port = 53
transport = "tcp"

# DNS-over-TLS (RFC 7858) — requires a valid certificate.
# [[listeners]]
# address = "0.0.0.0"
# port = 853
# transport = "dot"
# tls_cert = "/etc/heimdall/tls/cert.pem"
# tls_key  = "/etc/heimdall/tls/key.pem"

# DNS-over-HTTPS/2 (RFC 8484) — requires a valid certificate.
# [[listeners]]
# address = "0.0.0.0"
# port = 443
# transport = "doh"
# tls_cert = "/etc/heimdall/tls/cert.pem"
# tls_key  = "/etc/heimdall/tls/key.pem"

# DNS-over-QUIC (RFC 9250) — requires a valid certificate.
# [[listeners]]
# address = "0.0.0.0"
# port = 853
# transport = "doq"
# tls_cert = "/etc/heimdall/tls/cert.pem"
# tls_key  = "/etc/heimdall/tls/key.pem"

# ── Zone files (authoritative role) ──────────────────────────────────────────
# Loaded at start-up; reloaded on SIGHUP.
# Requires roles.authoritative = true.

# [zones]
# [[zones.zone_files]]
# origin = "example.com."
# path   = "/var/lib/heimdall/zones/example.com"

# ── Cache ─────────────────────────────────────────────────────────────────────

[cache]
# Maximum number of RRsets to hold in the in-memory cache.
capacity = 1_000_000

# Minimum and maximum TTL enforced regardless of the wire value.
min_ttl_secs = 60
max_ttl_secs = 86400

# Serve stale cached answers this many seconds past expiry when the upstream
# is unreachable.  Disabled by default (RFC 8767 feature).
# serve_stale_secs = 300

# ── ACL ───────────────────────────────────────────────────────────────────────
# Access control lists restrict which clients may send queries.
# Format: CIDR range + optional permission flags (defined in specification/006).

# [acl]
# rules = [
#   "allow 10.0.0.0/8",
#   "allow 192.168.0.0/16",
#   "deny  0.0.0.0/0",
# ]

# ── Response rate limiting ────────────────────────────────────────────────────

[rate_limit]
# Enable response rate limiting (RFC 8906 semantics, THREAT-067).
enabled = false
# Maximum responses per second per /24 subnet.  Requires enabled = true.
# responses_per_second = 20

# ── Response Policy Zones ─────────────────────────────────────────────────────
# RPZ feeds for DNS firewall / blocking (specification/013-rpz.md).

# [[rpz]]
# zone   = "rpz.example.com."
# source = "axfr+notify://ns1.example.com"

# ── Observability ─────────────────────────────────────────────────────────────
# Prometheus metrics and optional OTLP distributed tracing.
# Binds to loopback by default (OPS-021, THREAT-028).

[observability]
# Prometheus text-format metrics endpoint.
# Curl: curl http://127.0.0.1:9090/metrics
metrics_port = 9090

# OTLP/gRPC endpoint for distributed tracing.  Disabled by default.
# tracing_otlp_endpoint = "http://otel-collector:4317"

# ── Admin-RPC ─────────────────────────────────────────────────────────────────
# Length-prefix-framed JSON over Unix Domain Socket (OPS-007..015).
# Defaults to loopback port 9443; TLS material enables mTLS protection.

[admin]
# Admin-RPC HTTP/2 port.  Change only if 9090 conflicts with metrics_port.
admin_port = 9443

# mTLS for admin-RPC (recommended in production).
# tls_cert = "/etc/heimdall/admin/cert.pem"
# tls_key  = "/etc/heimdall/admin/key.pem"

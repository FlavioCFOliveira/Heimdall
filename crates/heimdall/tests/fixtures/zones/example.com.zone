; example.com — basic test zone (Sprint 47 task #467)
; Covers: SOA, NS, A, AAAA, MX, CNAME, DNAME, TXT, wildcard
$ORIGIN example.com.
$TTL 300

@   IN SOA  ns1 hostmaster (
                2024010101 ; serial
                3600       ; refresh
                900        ; retry
                604800     ; expire
                300 )      ; minimum TTL

; Nameservers
@       IN NS   ns1
@       IN NS   ns2

; A / AAAA for the zone apex
@       IN A    192.0.2.1
@       IN AAAA 2001:db8::1

; Glue for nameservers
ns1     IN A    192.0.2.2
ns2     IN A    192.0.2.3

; MX records
@       IN MX   10 mail
@       IN MX   20 mail2

; Mail servers
mail    IN A    192.0.2.10
mail2   IN A    192.0.2.11

; CNAME chain: www → example.com.
www     IN CNAME @

; Deeper CNAME chain (two hops)
alias   IN CNAME www

; DNAME delegation (all of sub.example.com. → other.example.)
sub     IN DNAME other.example.

; TXT record (SPF-like)
@       IN TXT  "v=spf1 mx -all"

; Specific A record that will produce NODATA for AAAA queries
noaaaa  IN A    192.0.2.100

; Wildcard — matches any undefined name
*       IN A    192.0.2.254
*       IN TXT  "wildcard-match"

{
  "title": "Heimdall DNS",
  "uid": "heimdall-dns",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Query rate (queries/s)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(heimdall_queries_total{role=\"authoritative\"}[1m])",
          "legendFormat": "authoritative"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(heimdall_queries_total{role=\"recursive\"}[1m])",
          "legendFormat": "recursive"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cache hit ratio",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(heimdall_cache_hits_total{role=\"recursive\"}[1m]) / clamp_min(rate(heimdall_cache_hits_total{role=\"recursive\"}[1m]) + rate(heimdall_cache_misses_total{role=\"recursive\"}[1m]), 1)",
          "legendFormat": "recursive"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(heimdall_cache_hits_total{role=\"forwarder\"}[1m]) / clamp_min(rate(heimdall_cache_hits_total{role=\"forwarder\"}[1m]) + rate(heimdall_cache_misses_total{role=\"forwarder\"}[1m]), 1)",
          "legendFormat": "forwarder"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Admitted vs denied (req/s)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(heimdall_admitted_total[1m])",
          "legendFormat": "admitted"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(heimdall_acl_denied_total[1m])",
          "legendFormat": "acl denied"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(heimdall_rrl_dropped_total[1m])",
          "legendFormat": "rrl dropped"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(heimdall_query_rl_refused_total[1m])",
          "legendFormat": "rate limited"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Heimdall up",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "heimdall_up",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Config reload generation",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "heimdall_reload_generation",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "hide": 0,
        "includeAll": false,
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  }
}

; example.com test zone for container image smoke tests (task #483).
; Used exclusively for verifying that Heimdall serves authoritative DNS
; responses over UDP and TCP from inside the container.
$ORIGIN example.com.
$TTL    3600
@       IN  SOA ns1.example.com. admin.example.com. (
                    2026050501  ; serial
                    3600        ; refresh
                    900         ; retry
                    604800      ; expire
                    300         ; minimum
                )
@       IN  NS  ns1.example.com.
@       IN  A   192.0.2.1
ns1     IN  A   192.0.2.1
www     IN  A   192.0.2.1
